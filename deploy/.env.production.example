# Copy to deploy/.env.production and fill in secrets (file is gitignored).
# docker compose -f docker-compose.prod.yml -f docker-compose.imentor.yml --env-file deploy/.env.production up -d --build

DJANGO_SECRET_KEY=replace-with-long-random-string
DJANGO_ALLOWED_HOSTS=api.imentor.uz
DJANGO_CORS_ALLOWED_ORIGINS=https://imentor.uz,https://www.imentor.uz
DJANGO_CSRF_TRUSTED_ORIGINS=https://imentor.uz,https://www.imentor.uz

# SQLite path inside the backend container is set by docker-compose.imentor.yml (/data/db.sqlite3).

# Optional: change if 31001/31002 clash with other apps on this server
# IMENTOR_FRONTEND_PORT=31001
# IMENTOR_BACKEND_PORT=31002

# Baked into the frontend static build (must match public API URL)
VITE_API_BASE_URL=https://api.imentor.uz/api

# Google Gemini — set only on the server in deploy/.env.production (not in git). Revoke any key exposed in chat.
GEMINI_API_KEY=
