# Use AFTER certbot issued certs under /etc/letsencrypt/live/imentor.uz/
# Copy: sudo cp ... /etc/nginx/sites-available/imentor && sudo ln -sf ... sites-enabled/imentor
# If certbot also edited sites-enabled/default for the same server_name, remove duplicates or disable default.
#
# Requires Docker frontend on 127.0.0.1:31001 and API on 127.0.0.1:31002

upstream imentor_frontend {
    server 127.0.0.1:31001;
    keepalive 8;
}

upstream imentor_api {
    server 127.0.0.1:31002;
    keepalive 8;
}

server {
    listen 80;
    listen [::]:80;
    server_name imentor.uz www.imentor.uz;
    return 301 https://$host$request_uri;
}

server {
    listen 80;
    listen [::]:80;
    server_name api.imentor.uz;
    return 301 https://$host$request_uri;
}

server {
    listen 443 ssl http2;
    listen [::]:443 ssl http2;
    server_name imentor.uz www.imentor.uz;

    ssl_certificate /etc/letsencrypt/live/imentor.uz/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/imentor.uz/privkey.pem;
    include /etc/letsencrypt/options-ssl-nginx.conf;
    ssl_dhparam /etc/letsencrypt/ssl-dhparams.pem;

    location / {
        proxy_pass http://imentor_frontend;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }
}

server {
    listen 443 ssl http2;
    listen [::]:443 ssl http2;
    server_name api.imentor.uz;

    ssl_certificate /etc/letsencrypt/live/imentor.uz/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/imentor.uz/privkey.pem;
    include /etc/letsencrypt/options-ssl-nginx.conf;
    ssl_dhparam /etc/letsencrypt/ssl-dhparams.pem;

    location / {
        proxy_pass http://imentor_api;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_read_timeout 120s;
    }
}
