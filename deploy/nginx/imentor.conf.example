# Copy to /etc/nginx/sites-available/imentor (do not overwrite default).
# Adjust upstream ports if you changed IMENTOR_*_PORT in .env.production.
# Enable: ln -s /etc/nginx/sites-available/imentor /etc/nginx/sites-enabled/imentor
# Test: nginx -t && systemctl reload nginx
# TLS: use certbot (certonly or --nginx) for imentor.uz, www, and api.
#
# If the browser still shows "Welcome to nginx!":
#   1) Confirm symlink exists: ls -la /etc/nginx/sites-enabled/ | grep imentor
#   2) Reload after edits: sudo nginx -t && sudo systemctl reload nginx
#   3) On the server: curl -sI -H "Host: imentor.uz" http://127.0.0.1 — expect 200 from your app (not nginx welcome HTML).
#   4) Ensure Docker is up and listening: ss -tlnp | grep 31001  (frontend must proxy to 127.0.0.1:31001)
# If curl returns 502: containers are down — run docker compose (see README Deploy section).

upstream imentor_frontend {
    server 127.0.0.1:31001;
    keepalive 8;
}

upstream imentor_api {
    server 127.0.0.1:31002;
    keepalive 8;
}

# After certificates exist, use real server blocks with ssl_certificate.
# HTTP → HTTPS redirect (certbot may inject these; merge carefully).

server {
    listen 80;
    listen [::]:80;
    server_name imentor.uz www.imentor.uz;

    location / {
        proxy_pass http://imentor_frontend;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }
}

server {
    listen 80;
    listen [::]:80;
    server_name api.imentor.uz;

    location / {
        proxy_pass http://imentor_api;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_read_timeout 120s;
    }
}
